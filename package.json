{
  "name": "@shuian/opencode-claude-mem",
  "version": "1.2.2",
  "type": "module",
  "description": "OpenCode plugin adapter for claude-mem persistent memory",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "bin": {
    "opencode-claude-mem": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "dist/cli.js",
    "skills/",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "claude-mem",
    "memory",
    "plugin",
    "ai"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun build src/cli/index.ts --target=node --outfile dist/cli.js",
    "build:cli": "bun build src/cli/index.ts --target=node --outfile dist/cli.js",
    "test": "bun test",
    "check": "bunx tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3wz/opencode-mem.git"
  },
  "homepage": "https://github.com/3wz/opencode-mem#readme",
  "bugs": {
    "url": "https://github.com/3wz/opencode-mem/issues"
  },
  "author": "shuian",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@clack/prompts": "latest",
    "@opencode-ai/plugin": "latest",
    "@types/bun": "latest",
    "picocolors": "latest",
    "typescript": "^5.0.0"
  }
}
